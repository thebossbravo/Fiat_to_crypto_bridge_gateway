# Server
PORT=8080

# Database (PostgreSQL)
BLUEPRINT_DB_HOST=localhost
BLUEPRINT_DB_PORT=5432
BLUEPRINT_DB_DATABASE=bridge_gateway
BLUEPRINT_DB_USERNAME=postgres
BLUEPRINT_DB_PASSWORD=postgres
BLUEPRINT_DB_SCHEMA=public

# JWT
JWT_SECRET=change-me-in-production-use-a-256bit-secret

# Blockradar API
BLOCKRADAR_API_KEY=your-blockradar-api-key
BLOCKRADAR_BASE_URL=https://api.blockradar.io/v1

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Webhook Secrets
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
BLOCKRADAR_WEBHOOK_SECRET=your-blockradar-webhook-secret
